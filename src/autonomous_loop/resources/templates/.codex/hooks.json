{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "autonomous-loop hook session-start",
            "timeout": 15,
            "statusMessage": "autonomous-loop continuity"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "autonomous-loop hook stop",
            "timeout": 60,
            "statusMessage": "autonomous-loop stop gate"
          }
        ]
      }
    ]
  }
}
